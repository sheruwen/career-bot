# 本檔只作為公開範例模板，請將真實設定放在 .env

# ===== 104 公開搜尋（預設來源） =====
WEB104_API_URL=https://www.104.com.tw/jobs/search/api/jobs
WEB104_KEYWORD=產品經理
WEB104_AREA=6001001000
WEB104_PAGES=5
WEB104_ORDER=15
# 可選：一次抓多種排序（逗號分隔），例如 15,16。若設定會優先於 WEB104_ORDER
WEB104_ORDERS=
WEB104_ASC=0
WEB104_TIMEOUT=20

# ===== Cake 公開搜尋（可選來源） =====
CAKE_BASE_URL=https://www.cake.me
CAKE_KEYWORD=產品經理
CAKE_LOCATION=
CAKE_PAGES=1
CAKE_TIMEOUT=20
CAKE_DETAIL_TIMEOUT=20
# 可選：覆蓋預設搜尋 URL。可使用 {keyword} / {keyword_raw} / {page} / {location} / {location_raw}
# CAKE_SEARCH_URL_TEMPLATE=https://www.cake.me/jobs/{keyword}?page={page}

# ===== Yourator 公開搜尋（可選來源） =====
YOURATOR_BASE_URL=https://www.yourator.co
YOURATOR_API_URL=https://www.yourator.co/api/v4/jobs
YOURATOR_KEYWORD=產品經理
YOURATOR_KEYWORDS="產品經理,專案經理,product manager,project manager,product owner,PO,APM"
YOURATOR_PAGES=10
YOURATOR_TIMEOUT=20

# ===== LINE Messaging API =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO_USER_ID=
LINE_PUSH_ENDPOINT=https://api.line.me/v2/bot/message/push
LINE_TIMEOUT=20

# ===== Google Sheets =====
GOOGLE_SHEETS_CREDENTIALS_FILE=/Users/wendy/.config/codex/google/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=Job List
GOOGLE_SHEETS_APPEND_HEADER=true
GOOGLE_SHEETS_CREATE_WORKSHEET_IF_MISSING=false
GOOGLE_SHEETS_HEADER_ROW=auto

# ===== 共用 Google OAuth（給 My Drive / 個人帳號授權流程使用） =====
GOOGLE_OAUTH_CLIENT_FILE=/Users/wendy/.config/codex/google/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=/Users/wendy/.config/codex/google/google-drive-token.json

# ===== 其他 API（保留擴充用） =====
JOB_API_URL=https://example.104.api/jobs
JOB_API_TOKEN=
JOB_API_QUERY=backend engineer
JOB_API_TIMEOUT=20
